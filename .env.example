# GhostMedia 统一配置（复制为 .env 后修改）
# cp .env.example .env

# =========================
# 全局共享 LLM（Trend + Content）
# =========================
GM_TIMEZONE=Asia/Shanghai
GM_LLM_PROVIDER=deepseek
GM_LLM_MODEL=deepseek-chat
GM_LLM_API_KEY=
GM_LLM_API_BASE=https://api.deepseek.com

# Trend 专用覆盖（可选）
# TREND_AI_MODEL=deepseek/deepseek-chat
# TREND_AI_API_KEY=
# TREND_AI_API_BASE=

# =========================
# Content（video）参数
# =========================
# 可选：单独覆盖，不填则使用 GM_* 的 LLM 设置
CONTENT_LLM_PROVIDER=
CONTENT_LLM_MODEL=
CONTENT_LLM_API_KEY=
CONTENT_LLM_API_BASE=

# 视频素材源 Key（逗号分隔多个）
CONTENT_PEXELS_API_KEYS=
CONTENT_PIXABAY_API_KEYS=

# 字幕方式：edge 或 whisper
CONTENT_SUBTITLE_PROVIDER=edge

# Azure Speech（正式版 Xiaoxiao / 风格化语音）
CONTENT_AZURE_SPEECH_KEY=
CONTENT_AZURE_SPEECH_REGION=

# =========================
# Social（auto-upload）参数
# =========================
SOCIAL_LOCAL_CHROME_PATH=
SOCIAL_LOCAL_CHROME_HEADLESS=false
SOCIAL_XHS_SERVER=http://127.0.0.1:11901

# =========================
# Trend 通知/存储（按需选填）
# =========================
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
WEWORK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=

S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# =========================
# Auto Cycle（4小时自动跑一轮）
# =========================
GM_AUTO_DOUYIN_ACCOUNT=main
GM_AUTO_ENABLE_DOUYIN=true
GM_AUTO_ENABLE_BILIBILI=true
GM_AUTO_BILIBILI_ACCOUNT_FILE=
GM_AUTO_STYLE_PROFILE=maoshenstyle
GM_AUTO_FOCUS_PLATFORMS=
GM_AUTO_NEWS_INDEX=1

# =========================
# Douyin Official API
# =========================
DOUYIN_OPEN_CLIENT_KEY=
DOUYIN_OPEN_CLIENT_SECRET=
DOUYIN_OPEN_REFRESH_TOKEN=
DOUYIN_OPEN_OPEN_ID=
